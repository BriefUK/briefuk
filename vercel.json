{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/cron-fetch.js": { "maxDuration": 60 },
    "api/cron-brit-bit.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron-fetch", "schedule": "0 6-22/2 * * *" },
    { "path": "/api/cron-brit-bit", "schedule": "0 8 * * 4" }
  ]
}
