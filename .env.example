ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxxxx.supabase.co
# Publishable key (Project Settings > API Keys). RLS-restricted to public
# SELECT only — used by the request-time read endpoints (api/news.js, api/brit-bit.js).
SUPABASE_ANON_KEY=sb_publishable_...
# Secret / service_role key (Project Settings > API Keys). Bypasses RLS —
# required for the cron jobs to write. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` to
# /api/cron-fetch and /api/cron-brit-bit. Must match the value set in
# Vercel project settings (Settings > Environment Variables). Optional for
# local dev — if unset, those endpoints accept any request.
CRON_SECRET=
